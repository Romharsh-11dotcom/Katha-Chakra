---
import Navbar from '../components/Navbar.astro';
import WorkGrid from '../components/WorkGrid.astro';
import About from '../components/About.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<!-- SEO: Title and Description are critical for Google ranking -->
		<title>KATHA CHAKRA | Production</title>
		<meta name="description" content="KATHA CHAKRA is a professional production house specializing in cinematic wedding films and creative music video production. Let us tell your story.">
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Import professional fonts -->
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400&display=swap" rel="stylesheet">
		
		<style>
			body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; color: #ffffff; margin: 0; }
			h1, h2, h3 { font-family: 'Playfair Display', serif; }
			
			/* Animation classes */
			.fade-in { animation: fadeInAnimation 1.5s ease-in; }
			@keyframes fadeInAnimation {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}
		</style>
	</head>
	<body>
		<Navbar />
		
		<main style="padding: 100px 50px; text-align: center;" class="fade-in">
			<h1 style="font-size: 4rem; margin-bottom: 20px;">Storytelling in Motion</h1>
			<p style="font-size: 1.2rem; opacity: 0.8;">Cinematic Wedding Films & Music Videos</p>
		</main>

        <div class="fade-in">
            <WorkGrid />
            <About />
            <ContactSection />
        </div>
        
        <Footer />
	</body>
</html>