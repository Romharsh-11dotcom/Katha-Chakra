---
<section style="padding: 80px 50px; background: #1a1a1a; color: #fff; text-align: center;">
  <h2 style="font-family: 'Playfair Display', serif; font-size: 2.5rem; margin-bottom: 40px;">Let’s Connect</h2>
  
  <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
    
    <!-- WhatsApp -->
    <a href={`https://wa.me/${whatsappNumber}`} target="_blank" rel="noopener noreferrer" style="padding: 15px 30px; background: #25D366; color: #fff; text-decoration: none; font-weight: bold; border-radius: 50px;">
      WhatsApp
    </a>

    <!-- Call -->
    <a href={`tel:${phoneNumber}`} style="padding: 15px 30px; background: #C3B091; color: #000; text-decoration: none; font-weight: bold; border-radius: 50px;">
      Call Now
    </a>

    <!-- Email -->
    <a href={`mailto:${emailAddress}`} style="padding: 15px 30px; background: #fff; color: #000; text-decoration: none; font-weight: bold; border-radius: 50px;">
      Email Us
    </a>
    
  </div>
</section>