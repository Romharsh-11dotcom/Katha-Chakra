---
const projects = [
  // ONLY use the video ID here, not the full link
  { id: "video1", title: "Bride", category: "Wedding Reel", youtubeId: "Arnlacfag3A" },
  { id: "video2", title: "Memories in Bloom", category: "Wedding Film", youtubeId: "YOUR_ID_2" },
  { id: "video3", title: "Rhythm & Soul", category: "Upcoming Music Video", youtubeId: "YOUR_ID_3" },
];
---

<section id="work-grid" style="padding: 50px; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
  {projects.map(project => (
    <button 
      class="video-trigger"
      data-video-id={project.id}
      style="background: none; border: none; padding: 0; text-align: left; cursor: pointer; width: 100%;"
    >
      <div class="project-card" style="background: #1a1a1a; padding: 20px; border-left: 4px solid #C3B091; transition: all 0.3s ease;">
        <h3 style="margin: 0; color: #ffffff;">{project.title}</h3>
        <p style="margin: 5px 0 0 0; font-size: 0.9rem; color: #C3B091;">{project.category}</p>
      </div>
    </button>

    <div id={project.id} class="modal" style="display:none; position:fixed; z-index:1000; left:0; top:0; width:100%; height:100%; background-color:rgba(0,0,0,0.95); justify-content:center; align-items:center; flex-direction: column;">
      <span class="close-btn" style="cursor:pointer; position:absolute; top:20px; right:30px; font-size:40px; color:white; z-index:1001;">&times;</span>
      
      <iframe 
        width="80%" 
        height="500px" 
        src={`https://www.youtube.com/embed/${project.youtubeId}`} 
        style="max-width: 800px; border-radius: 10px; border: none;"
        allowfullscreen>
      </iframe>

      <a href={`https://www.youtube.com/watch?v=${project.youtubeId}`} target="_blank" style="margin-top: 20px; color: #C3B091; text-decoration: none; border: 1px solid #C3B091; padding: 10px 20px; border-radius: 5px;">
        Watch on YouTube
      </a>
    </div>
  ))}
</section>

<script>
  document.getElementById('work-grid')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest('.video-trigger') as HTMLElement;
    
    if (trigger) {
      const id = trigger.getAttribute('data-video-id');
      const modal = document.getElementById(id!);
      if (modal) modal.style.display = 'flex';
    }

    if (target.classList.contains('close-btn')) {
      const modal = target.parentElement!;
      modal.style.display = 'none';
      
      // Stop the YouTube video by clearing the src
      const iframe = modal.querySelector('iframe');
      if (iframe) {
        const originalSrc = iframe.src;
        iframe.src = '';
        iframe.src = originalSrc;
      }
    }
  });
</script>
